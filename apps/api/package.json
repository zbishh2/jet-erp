{
  "name": "@jet-erp/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.dev.toml",
    "dev:local": "wrangler dev --local --config wrangler.dev.toml",
    "deploy": "wrangler deploy",
    "build": "tsc",
    "lint": "eslint src --ext ts",
    "test": "vitest",
    "clean": "rimraf dist node_modules",
    "db:generate": "drizzle-kit generate --config drizzle.config.d1.ts",
    "db:migrate:local": "wrangler d1 migrations apply jet-erp-db-local --local --config wrangler.dev.toml",
    "db:migrate:remote": "wrangler d1 migrations apply jet-erp-db --remote"
  },
  "dependencies": {
    "@jet-erp/shared": "*",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "jose": "^6.1.3",
    "resend": "^4.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.0",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/node": "^20.10.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.0",
    "wrangler": "^3.114.17"
  }
}
