	column FirstDayOfMonth = ```
			
			DATE(
			    YEAR(dwdate[date]),
			    MONTH(dwdate[date]),
			    1
			)
			
			```
		formatString: Short Date
		lineageTag: 4e26f330-dab1-4a4c-bb48-b70c410a2090
		summarizeBy: none

