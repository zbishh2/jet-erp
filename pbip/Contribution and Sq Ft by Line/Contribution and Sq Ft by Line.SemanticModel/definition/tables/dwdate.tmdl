		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'Is Workday' = ```
			
			IF(
			    WEEKDAY([Date], 2) < 6 && 
			    NOT(
			        CONTAINS(
			            cr60f_holidays, 
			            cr60f_holidays[Date], 
			            [Date]
			        )
			    ), 
			    "Yes", 
			    "No"
			)
			
			```
		lineageTag: 5cde045f-449d-4d07-9be7-1075a294f8bc
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column DateExistsInInvoice = ```
			
			IF(
			    NOT ISEMPTY(RELATEDTABLE('espInvoiceLine')),
			    "Yes",
			    "No"
			)
			
			```
		lineageTag: 1cef83d2-f269-4cba-bc8b-ce53a81e17cf
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Week End' = dwdate[date] - WEEKDAY(dwdate[date])+7
