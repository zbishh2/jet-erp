	column Date
		formatString: Short Date
		lineageTag: cdbd8e22-634c-476d-a6de-434963c1c58b
		summarizeBy: none
		isNameInferred
		sourceColumn: ReportDates[Date]

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition 'Date Periods' = calculated
		mode: import
		source =
				
				UNION (
				    ADDCOLUMNS (DATESMTD ( 'ReportDates'[Date] ), "Type", "MTD", "Sort", 1),
				    ADDCOLUMNS (DATESQTD ( 'ReportDates'[Date] ), "Type", "QTD", "Sort", 2),
				    ADDCOLUMNS (DATESYTD ( 'ReportDates'[Date] ), "Type", "YTD", "Sort", 3),
				    ADDCOLUMNS (
				        PREVIOUSMONTH (DATESMTD ( 'ReportDates'[Date] )),
				        "Type", "Last Month",
				        "Sort", 4
				    ),
				    ADDCOLUMNS (
				        PREVIOUSQUARTER (DATESQTD ( 'ReportDates'[Date] )),
				        "Type", "Last Qtr",
				        "Sort", 5
				    ),
				    ADDCOLUMNS (
				        PREVIOUSYEAR (DATESYTD ( 'ReportDates'[Date] )),
				        "Type", "Last Year",
				        "Sort", 6
				    ),
				    ADDCOLUMNS (
				        CALENDAR (MIN ( espInvoice[transactiondate - Copy] ), MAX ( espInvoice[transactiondate - Copy] )),
				        "Type", "All Time",
				        "Sort", 7
				    ),
				    ADDCOLUMNS (
				        CALENDAR (MIN ( 'ReportDates'[Date] ), MAX ( 'ReportDates'[Date] )),
				        "Type", "Custom",
				        "Sort", 8
				    )
				)

	annotation PBI_Id = e0450361619648a6869b69d0efc96c52

