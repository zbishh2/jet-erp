	column 'Month Year' = espInvoiceLine[Month] & " " & espInvoiceLine[Year]
		lineageTag: 854b2d19-90b2-4831-8a93-4d177592946b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Sales Last Year Same Month' = ```
			
			VAR CurrentYear = YEAR(espInvoiceLine[transaction date])
			VAR CurrentMonth = MONTH(espInvoiceLine[transaction date])
			VAR PreviousYearSales = CALCULATE(
			    SUM(espInvoiceLine[Total Sales]),
			    FILTER(
			        ALL(espInvoiceLine),
			        YEAR(espInvoiceLine[transaction date]) = CurrentYear - 1 &&
			        MONTH(espInvoiceLine[transaction date]) = CurrentMonth
			    )
			)
			RETURN
			PreviousYearSales
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 123ea0e0-48cb-4087-a878-b10645ef3ff0
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column 'Last Years Sales' = espInvoiceLine[Sales Last Year Same Month]/espInvoiceLine[Number of Similar Rows]
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 6c348454-ceee-497d-a609-5abc16dd8d99
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column 'Contribution $ Last Year Same Month' =
			
			VAR CurrentYear = YEAR(espInvoiceLine[transaction date])
			VAR CurrentMonth = MONTH(espInvoiceLine[transaction date])
			VAR PreviousYearSales = CALCULATE(
			    SUM(espInvoiceLine[Contribution $]),
			    FILTER(
			        ALL(espInvoiceLine),
			        YEAR(espInvoiceLine[transaction date]) = CurrentYear - 1 &&
			        MONTH(espInvoiceLine[transaction date]) = CurrentMonth
			    )
			)
			RETURN
			PreviousYearSales
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: a6a25fed-01b1-4717-bdcf-577fd6bf3259
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column 'Contribution $' = espInvoiceLine[Total Sales] - espInvoiceLine[Estimated cost]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 32ad331d-9fe0-47f3-baba-1aabd11fe388
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	column 'Last year' = espInvoiceLine[Year]-1
		formatString: 0
		lineageTag: e55cf43e-8b29-41c0-bc84-6393397db6c9
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column SumLastYearSales = ```
			
			CALCULATE(
			    SUM(espInvoiceLine[Total Sales]), 
			    FILTER(
			        ALL(espInvoiceLine),
			        espInvoiceLine[Month Year] = EARLIER(espInvoiceLine[Month Last Year])
			    )
			)
			
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 37e286a6-ecf5-4226-b552-3280acd3b5ba
