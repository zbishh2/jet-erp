	column 'Optimum Run Speed' = CALCULATE(MAX(dwproductionfeedback[dwcostcenters.optimum_run_speed]),RELATEDTABLE(dwproductionfeedback))
		formatString: 0
		lineageTag: 5357d420-e698-4fe1-a07d-43ca01e60339
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column 'Spec Standard Speed (MaxSpeedBelowOptimum)' = ```
			
			VAR OptimumSpeed = [Optimum Run Speed]
			VAR CutoffDate = EDATE(TODAY(), -18)   // 18 months back from today
			RETURN
			    CALCULATE(
			        MAX(dwproductionfeedback[Actual Speed]),
			        FILTER(
			            dwproductionfeedback,
			            dwproductionfeedback[Line/Spec] = EARLIER(DistinctLineSpec[ID]) &&
			            dwproductionfeedback[Actual Speed] < OptimumSpeed &&
			            dwproductionfeedback[feedback_report_date] >= CutoffDate
			        )
			    )
			
			
			
			```
		formatString: 0
		lineageTag: 7a01b830-8381-4206-8070-1fba2c9b5432
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column AverageRunSpeed = ```
			
			VAR OptimumSpeed = [Optimum Run Speed]
			RETURN
			    CALCULATE(
			        AVERAGE(dwproductionfeedback[Actual Speed]),
			        FILTER(
			            dwproductionfeedback,
			            dwproductionfeedback[Line/Spec] = EARLIER('DistinctLineSpec'[ID]) &&
			            dwproductionfeedback[Actual Speed] <= OptimumSpeed
			        )
			    )
			
			```
		formatString: 0
		lineageTag: 36c1b9a1-d99f-4854-8cc0-9318a63054de
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column MedianRunSpeed = CALCULATE(MEDIAN(dwproductionfeedback[Actual Speed]),RELATEDTABLE(dwproductionfeedback))
		formatString: 0
		lineageTag: ef219ed4-710b-4802-b841-e3478792b27a
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column 'Max - average' = DistinctLineSpec[Spec Standard Speed (MaxSpeedBelowOptimum)]-DistinctLineSpec[AverageRunSpeed]
		formatString: 0
		lineageTag: c4d15282-49d8-4698-9dd2-dd5d0f3a76aa
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column 'Count Of Runs' = CALCULATE(COUNT(dwproductionfeedback[Job num]), RELATEDTABLE(dwproductionfeedback))
		formatString: 0
		lineageTag: 0a789931-d3fa-4f66-aada-2b8862042c79
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition DistinctLineSpec = calculated
		mode: import
		source = ```
				
				VAR FilteredTable =
				    FILTER(
				        dwproductionfeedback,
				        dwproductionfeedback[Is Machine] = "Yes"
				    )
				RETURN
				    SUMMARIZE(
				        FilteredTable,
				        dwproductionfeedback[Line Number],
				        dwproductionfeedback[dwproductionorders.spec_number]
				        
				    )
				
				
				
				```

	annotation PBI_Id = b885f5632f794ec0bcbbbca0d1782eae

