	column 'Week Type' = If('Date Periods'[Type] = "YTD" || 'Date Periods'[Type]="QTD" || 'Date Periods'[Type]="Last 12 Weeks" || 'Date Periods'[Type]="Last 4 Weeks" || 'Date Periods'[Type]="Last Week" || 'Date Periods'[Type]="All Time" ,'Date Periods'[Type],BLANK())
		lineageTag: 40c1606a-e12e-4191-bac0-1952cfc0e346
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Column = TODAY() - WEEKDAY(TODAY(),2)-6
		formatString: General Date
		lineageTag: 6bdc9100-761e-4db1-9efb-08e2421e4125
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 019aafd1-6425-4ae2-8e05-69b8bd677431
			defaultHierarchy: LocalDateTable_7b432642-7d43-45ba-b3ee-e3c5d201f6c8.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column 'Macro Type' = If('Date Periods'[Type] = "Last Year" || 'Date Periods'[Type]="YTD" || 'Date Periods'[Type] = "QTD" || 'Date Periods'[Type] = "Last Quarter" ,'Date Periods'[Type],BLANK())
		lineageTag: 2836d639-30c6-492a-936f-06d2f379e47b
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	partition 'Date Periods' = calculated
		mode: import
		source = ```
				
				UNION (
				    ADDCOLUMNS (DATESMTD ( 'ReportDates'[Date] ), "Type", "MTD", "Sort", 1),
				    ADDCOLUMNS (DATESQTD ( 'ReportDates'[Date] ), "Type", "QTD", "Sort", 2),
				    ADDCOLUMNS (DATESYTD ( 'ReportDates'[Date] ), "Type", "YTD", "Sort", 3),
				    ADDCOLUMNS (
				        PREVIOUSMONTH (DATESMTD ( 'ReportDates'[Date] )),
				        "Type", "Last Month",
				        "Sort", 4
				    ),
				    ADDCOLUMNS (
				        PREVIOUSQUARTER (DATESQTD ( 'ReportDates'[Date] )),
				        "Type", "Last Qtr",
				        "Sort", 5
				    ),
				    ADDCOLUMNS (
				        PREVIOUSYEAR (DATESYTD ( 'ReportDates'[Date] )),
				        "Type", "Last Year",
				        "Sort", 6
				    ),
				    ADDCOLUMNS (
				        CALENDAR (MIN ( dwproductionfeedback[feedback_report_date] ), MAX ( dwproductionfeedback[feedback_report_date] )),
				        "Type", "All Time",
				        "Sort", 7
				    ),
				ADDCOLUMNS (
				    CALENDAR (
				        TODAY() - WEEKDAY(TODAY(), 2) - 6,  -- Previous Monday
				        TODAY()  -- Include this week to date
				    ),
				    "Type", "Last Week",
				    "Sort", 8
				),
				ADDCOLUMNS (
				    CALENDAR (
				        TODAY() - WEEKDAY(TODAY(), 2) - (7 * 4) + 1,  -- Start: Monday 4 weeks ago
				        TODAY()  -- End: today
				    ),
				    "Type", "Last 4 Weeks",
				    "Sort", 9
				),
				
				ADDCOLUMNS (
				    CALENDAR (
				        TODAY() - WEEKDAY(TODAY(), 2) - (7 * 12) + 1,  -- Start: Monday 12 weeks ago
				        TODAY()  -- End: today
				    ),
				    "Type", "Last 12 Weeks",
				    "Sort", 10
				),
				    ADDCOLUMNS (
				        CALENDAR (
				            VAR Today = TODAY()
				            VAR LastWorkDay = SWITCH(WEEKDAY(Today, 2), 1, Today - 3, Today - 1)
				            RETURN LastWorkDay,
				            VAR Today = TODAY()
				            VAR LastWorkDay = SWITCH(WEEKDAY(Today, 2), 1, Today - 3, Today - 1)
				            RETURN LastWorkDay
				        ),
				        "Type", "Last Work Day",
				        "Sort", 11
				    ),
				    ADDCOLUMNS (
				    CALENDAR (
				        EOMONTH ( TODAY(), -3 ) + 1,  -- Start of two months ago (Feb 1 if today is April)
				        EOMONTH ( TODAY(), -1 )       -- End of last month (March 31 if today is April)
				    ),
				    "Type", "Last 2 Months",
				    "Sort", 12
				),
				ADDCOLUMNS (
				    CALENDAR (
				        EOMONTH ( TODAY(), -4 ) + 1,  -- Start of 3 months ago (if today is April 9, start Jan 1)
				        EOMONTH ( TODAY(), -1 )       -- End of last month (March 31)
				    ),
				    "Type", "Last 3 Months",
				    "Sort", 13
				)
				
				)
				
				```

	annotation PBI_Id = b4724adc62704bbcb6254e497af46792

