		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Sheets Out' = If(AND(dwproductionfeedback[Machine_Count]>1,or(dwproductionfeedback[Line Number]="154",dwproductionfeedback[Machine ..]="9002 Strapper")),dwproductionfeedback[Quantity Produced]/dwproductionfeedback[Number In],dwproductionfeedback[Quantity Produced]/dwproductionfeedback[Number out (entry/exit)])
