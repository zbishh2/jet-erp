	column 'Full Sheets Produced' = If(dwproductionfeedback[Machine Name & #] = "9002 Strapper" || dwproductionfeedback[Machine Name & #] = "7996 Transfer In", dwproductionfeedback[Quantity Produced]/dwproductionfeedback[Max Number Out],BLANK() )
