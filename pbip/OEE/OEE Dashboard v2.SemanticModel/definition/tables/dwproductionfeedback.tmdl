	column 'Number In' = IF(dwproductionfeedback[dwjobseriesstep.number_up_entry_1]=dwproductionfeedback[dwjobseriesstep.number_up_exit_1] , dwproductionfeedback[Number out (entry/exit)], IF(dwproductionfeedback[Number out (entry/exit)]<dwproductionfeedback[Max Number Out],dwproductionfeedback[Max Number Out],dwproductionfeedback[dwjobseriesstep.number_up_exit_1]))
