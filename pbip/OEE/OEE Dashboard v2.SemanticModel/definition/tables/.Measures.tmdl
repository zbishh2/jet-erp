	measure LastQuarterText = ```
			
			VAR CurrentMonth = MONTH(TODAY())
			VAR CurrentQuarter = QUOTIENT(CurrentMonth - 1, 3) + 1
			VAR LastQuarter = 
			    IF(CurrentQuarter = 1, 4, CurrentQuarter - 1)
			RETURN
			    SWITCH(
			        LastQuarter,
			        1, "1st Quarter Performance Award",
			        2, "2nd Quarter Performance Award",
			        3, "3rd Quarter Performance Award",
			        4, "4th Quarter Performance Award"
			    )
			
			```
		displayFolder: Date/Time Logic
		lineageTag: e4ef3087-7d89-4f49-8c1d-89d9e7438d4b

