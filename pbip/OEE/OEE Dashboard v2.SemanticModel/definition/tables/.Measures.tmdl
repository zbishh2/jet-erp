	measure 'OEE % Change Last Month' = ```
			
			DIVIDE([OEE Last Month] - [OEE 2 Months Ago], [OEE 2 Months Ago])
			
			```
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Month Over Month
		lineageTag: 799b0978-8717-4671-ae1b-26a52ff848ea

	measure 'OEE Change Status' = ```
			
			VAR Change = DIVIDE([OEE Last Month] - [OEE 2 Months Ago], [OEE 2 Months Ago])
			RETURN
			    SWITCH(
			        TRUE(),
			        Change > 0, "▲ OEE Improved",
			        Change < 0, "▼ OEE Declined",
			        "➔ OEE Was Sustained"
			    )
			
			```
		displayFolder: Month Over Month
		lineageTag: e8ed2077-f91e-49ec-aaa3-7eb557820b29

	measure 'OEE Change % Formatted' = ```
			
			VAR Change = 
			    DIVIDE([OEE Last Month] - [OEE 2 Months Ago], [OEE 2 Months Ago])
			
			RETURN
			    FORMAT(Change, "0.0%")
			
			```
		displayFolder: Month Over Month
		lineageTag: 206891ec-5dad-4cb5-aac9-194c5ea228bb

	measure 'OEE Change Arrow SVG' = ```
			
			VAR Change = [OEE Last Month] - [OEE 2 Months Ago]
			RETURN
			    SWITCH(
			        TRUE(),
			        Change > 0, 
			            "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20'><polygon points='10,0 0,20 20,20' style='fill:green;' /></svg>",
			        Change < 0, 
			            "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='20' height='20'><polygon points='0,0 20,0 10,20' style='fill:red;' /></svg>",
