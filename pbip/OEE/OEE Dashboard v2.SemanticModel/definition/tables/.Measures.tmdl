	measure SoQ = DATE( YEAR( TODAY() ), ( QUARTER( TODAY() ) - 1 ) * 3 + 1, 1 )
		formatString: General Date
		displayFolder: Date/Time Logic
		lineageTag: 1f6b9fc4-dcf5-487e-bdf3-49c6f5eff8a7

	measure SoLQ = DATE( YEAR( TODAY() ), ( QUARTER( TODAY() ) - 1 ) * 2 + 1, 1 )
		formatString: General Date
		displayFolder: Date/Time Logic
		lineageTag: b6cebd61-b9d5-47b3-9850-ac3d832b20c0

	measure EoQ = DATE( YEAR( TODAY() ), QUARTER( TODAY() ) * 3 + 1, 1 ) - 1
		formatString: General Date
		displayFolder: Date/Time Logic
		lineageTag: 52b7ade7-45a3-4f7f-8b02-b34886c5519b

	measure EoLQ = DATE( YEAR( TODAY() ), QUARTER( TODAY() ) * 2 + 2, 1 ) - 1
		formatString: General Date
		displayFolder: Date/Time Logic
		lineageTag: 497f238e-736c-41ac-9322-83307c1f4e32

	measure 'OEE Best Quarter' = ```
			
			VAR MinDate = 
			    EDATE([SoQ], -12) -- 12 months (4 quarters) before SoQ
			VAR MaxDate = 
			    [SoQ] -- SoQ is the max date
			VAR MaxOEEQuarter =
			    MAXX(
			        SUMMARIZE(
			            FILTER(
			                ALL(dwdate),
			                dwdate[date] >= MinDate && dwdate[date] <= MaxDate -- Restrict dates to 1-year window
			            ),
			            dwdate[Year],
			            dwdate[Quarter],
			            "QuarterOEE", CALCULATE([OEE %])
			        ),
			        [QuarterOEE]
			    )
			RETURN
			    MaxOEEQuarter
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Month Over Month
		lineageTag: 1db2131c-1909-424e-8459-f396ffdbf207

	measure 'OEE Current Quarter' =
			
			CALCULATE(
			    [OEE %],
			    FILTER(
			        ALL(dwdate),
			        dwdate[date] >= [SoQ] && dwdate[date] <= [EoQ]
			    )
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Month Over Month
		lineageTag: 1e78e456-b069-4c95-8f5b-46ad6981e149

	measure 'OEE Last Quarter' =
			
			CALCULATE(
			    [OEE %],
			    FILTER(
			        ALL(dwdate),
			        dwdate[date] >= [SoLQ] && dwdate[date] <= [EoLQ]
			    )
			)
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: Month Over Month
		lineageTag: 6cdcedb5-7bc4-48ac-a2aa-c4704983a848

	measure 'OEE Difference to Best' = [OEE Current Quarter]- [OEE Best Quarter]
		formatString: 0.0%;-0.0%;0.0%
