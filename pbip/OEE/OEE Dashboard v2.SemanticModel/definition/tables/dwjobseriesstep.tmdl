	partition dwjobseriesstep = m
		mode: import
		source =
				let
				    Source = Sql.Databases("192.168.1.12"),
				    kdw_master = Source{[Name="kdw_master"]}[Data],
				    dbo_dwjobseriesstep = kdw_master{[Schema="dbo",Item="dwjobseriesstep"]}[Data]
				in
				    dbo_dwjobseriesstep

