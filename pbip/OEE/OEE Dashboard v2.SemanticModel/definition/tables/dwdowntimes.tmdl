	column 'Run Open downtime hours' = If(dwdowntimes[downtime_within]="RUN",IF(AND(dwdowntimes[downtime_closed_flag] = FALSE(), dwdowntimes[check_downtime_crosses_shift] = "OK"),dwdowntimes[downtime_duration_seconds]/3600,BLANK()),BLANK())
		lineageTag: b24f9275-e795-4c2c-853e-5720712738c7
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Closed downtime hours' = IF(AND(dwdowntimes[downtime_closed_flag] = TRUE(), dwdowntimes[check_downtime_crosses_shift] = "OK"),dwdowntimes[downtime_duration_seconds]/60/60,BLANK())
		lineageTag: 7bbe3d55-0acc-4ec9-a6ac-c6607c35bce2
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Setup Open downtime hours' = If(dwdowntimes[downtime_within]="SETUP",IF(AND(dwdowntimes[downtime_closed_flag] = FALSE(), dwdowntimes[check_downtime_crosses_shift] = "OK"),dwdowntimes[downtime_duration_seconds]/3600,BLANK()),BLANK())
		lineageTag: 0474e44c-a0c0-48d1-8508-d18332c42443
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Open Downtime Hours' = IF(AND(dwdowntimes[downtime_closed_flag] = FALSE(), dwdowntimes[check_downtime_crosses_shift] = "OK"),dwdowntimes[downtime_duration_seconds]/60/60,BLANK())
		lineageTag: 370705de-1065-40c2-8fc6-f8ece9312dc5
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Setup Closed downtime hours' = If(dwdowntimes[downtime_within]="SETUP",IF(AND(dwdowntimes[downtime_closed_flag] = TRUE(), dwdowntimes[check_downtime_crosses_shift] = "OK"),dwdowntimes[downtime_duration_seconds]/3600,BLANK()))
		lineageTag: 1fb7a91f-9c96-4377-8d82-32491bfda730
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 'Run Closed downtime hours' = If(dwdowntimes[downtime_within]="RUN",IF(AND(dwdowntimes[downtime_closed_flag] = TRUE(), dwdowntimes[check_downtime_crosses_shift] = "OK"),dwdowntimes[downtime_duration_seconds]/3600,BLANK()),BLANK())
		lineageTag: 350984a3-e0fa-484f-93b0-454555a7e8af
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	partition dwdowntimes = m
		mode: import
		source =
				let
				    Source = Sql.Databases("192.168.1.12"),
				    kdw_master = Source{[Name="kdw_master"]}[Data],
				    dbo_dwdowntimes = kdw_master{[Schema="dbo",Item="dwdowntimes"]}[Data]
				in
				    dbo_dwdowntimes

	annotation PBI_ResultType = Table

