	column 'Wasted Sheets' = If(dwproductionorders[Sheets Out]>dwproductionorders[Sheets In] || ISBLANK(dwproductionorders[Sheets Out]) || ISBLANK(dwproductionorders[Sheets In]),CALCULATE(SUM(dwproductionfeedback[rolled up wasted quantity reported]),RELATEDTABLE(dwproductionfeedback)),dwproductionorders[Sheets In]-dwproductionorders[Sheets Out])
