# ============================================================================
# Kiwiplan Gateway Configuration
# ============================================================================
# Copy this file to .env and fill in values
# NEVER commit .env to source control

# Server
PORT=3001
HOST=127.0.0.1

# ============================================================================
# Database Connection (Kiwiplan SQL Server)
# ============================================================================
# IMPORTANT: Use the read-only user created by sql/create-readonly-user.sql
# Do NOT use admin accounts (sa, jetkdw, etc.) - they have write access!

DB_SERVER=192.168.1.12
DB_DATABASE=esp
DB_USER=leango_gateway_ro
DB_PASSWORD=your-secure-password-here

# KDW Database (Kiwiplan Data Warehouse - same server, different database)
# The read-only user must have db_datareader on this database too
KDW_DATABASE=kdw_master

# ============================================================================
# Safety Settings
# ============================================================================
# TEST_COMPANY_ID is REQUIRED in dev mode
# This filters ALL queries to only see this company's data
# Find test company: node find-test-company.js

TEST_COMPANY_ID=2

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=info
LOG_QUERIES=true

# Audit logs are written to ./logs/audit-YYYY-MM-DD.log

# ============================================================================
# CORS (comma-separated origins)
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================================================
# Service Authentication
# ============================================================================
# REQUIRED when exposing via Cloudflare Tunnel or any non-private network.
# When set, all requests (except /health) must include:
#   Authorization: Bearer <token>
#
# Generate a secure token: openssl rand -hex 32
#
# Leave commented for private on-prem deployment behind firewall.
# SERVICE_TOKEN=your-secure-token-here
